build --action_env=BAZEL_CXXOPTS="-std=c++20"
build --repo_env=C_INCLUDE_PATH="/usr/include/glib-2.0:/usr/lib/x86_64-linux-gnu/glib-2.0/include:/usr/include/libmount:/usr/include/blkid"
build --repo_env=CPLUS_INCLUDE_PATH="/usr/include/glib-2.0:/usr/lib/x86_64-linux-gnu/glib-2.0/include:/usr/include/libmount:/usr/include/blkid"
build --action_env=C_INCLUDE_PATH="/usr/include/glib-2.0:/usr/lib/x86_64-linux-gnu/glib-2.0/include:/usr/include/libmount:/usr/include/blkid"
build --action_env=CPLUS_INCLUDE_PATH="/usr/include/glib-2.0:/usr/lib/x86_64-linux-gnu/glib-2.0/include:/usr/include/libmount:/usr/include/blkid"
# Definition of --config=memcheck
build:memcheck --strip=never --test_timeout=3600
common --enable_bzlmod
